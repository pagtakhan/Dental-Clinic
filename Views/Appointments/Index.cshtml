@model List<DentalClinic.Models.Appointment>
@{ ViewData["Title"] = "Appointments"; }

<div class="max-w-7xl mx-auto px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="font-h2 text-h2 text-on-surface">Appointments</h1>
            <p class="text-on-surface-variant text-sm mt-1">Manage and track all dental appointments</p>
        </div>
        @if (User.IsInRole("Patient") || User.IsInRole("Admin"))
        {
            <a asp-action="Book" class="bg-primary text-on-primary font-button text-button py-3 px-6 rounded-full hover:bg-primary-container hover:shadow-lg active:scale-95 transition-all duration-200 flex items-center gap-2">
                <span class="material-symbols-outlined text-[20px]">add</span>
                Book Appointment
            </a>
        }
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-surface-container-low border-b border-slate-100">
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Date & Time</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Patient</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Dentist</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Purpose</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Status</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-center py-16 text-on-surface-variant">
                            <span class="material-symbols-outlined text-5xl text-outline mb-3 block">calendar_today</span>
                            No appointments found.
                        </td></tr>
                    }
                    @foreach (var a in Model)
                    {
                        <tr class="border-b border-slate-50 hover:bg-surface-container-low transition-colors">
                            <td class="py-4 px-6 font-medium text-on-surface whitespace-nowrap">@a.AppointmentDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td class="py-4 px-6 text-on-surface-variant">@(a.Patient?.FullName ?? "—")</td>
                            <td class="py-4 px-6 text-on-surface-variant">@(a.Dentist != null ? "Dr. " + a.Dentist.FullName : "—")</td>
                            <td class="py-4 px-6 text-on-surface-variant max-w-[180px] truncate">@a.Purpose</td>
                            <td class="py-4 px-6">
                                <span class="px-3 py-1 rounded-full text-xs font-semibold
                                    @(a.Status=="Scheduled"?"bg-sky-100 text-sky-700":a.Status=="Completed"?"bg-green-100 text-green-700":"bg-red-100 text-red-700")">
                                    @a.Status
                                </span>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@a.AppointmentId"
                                       class="text-primary hover:underline font-label-sm">View</a>
                                    @if (a.Status == "Scheduled")
                                    {
                                        @if (User.IsInRole("Admin") || User.IsInRole("Dentist"))
                                        {
                                            <form method="post" asp-action="Complete" asp-route-id="@a.AppointmentId"
                                                  onsubmit="return confirm('Mark as completed?')" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="text-green-600 hover:underline font-label-sm">Complete</button>
                                            </form>
                                        }
                                        <form method="post" asp-action="Cancel" asp-route-id="@a.AppointmentId"
                                              onsubmit="return confirm('Cancel this appointment?')" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-error hover:underline font-label-sm">Cancel</button>
                                        </form>
                                    }
                                    @if (a.Status == "Completed" && User.IsInRole("Admin") && a.Billing == null)
                                    {
                                        <a asp-controller="Billing" asp-action="Generate" asp-route-appointmentId="@a.AppointmentId"
                                           class="text-secondary hover:underline font-label-sm">Bill</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
