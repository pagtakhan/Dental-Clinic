@model DentalClinic.Models.Appointment
@{ ViewData["Title"] = "Appointment Details"; }

<div class="max-w-4xl mx-auto px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="font-h2 text-h2 text-on-surface">Appointment Details</h1>
            <p class="text-on-surface-variant text-sm mt-1">Appointment #@Model.AppointmentId</p>
        </div>
        <a asp-action="Index" class="flex items-center gap-2 text-on-surface-variant hover:text-primary font-button transition-colors">
            <span class="material-symbols-outlined">arrow_back</span> Back
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <!-- Appointment Info -->
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <h3 class="font-h3 text-h3 text-on-surface mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">calendar_today</span> Appointment Info
            </h3>
            <div class="space-y-3">
                <div class="flex items-center justify-between py-2 border-b border-slate-50">
                    <span class="text-on-surface-variant text-sm">Date & Time</span>
                    <span class="font-semibold text-on-surface">@Model.AppointmentDate.ToString("MMMM dd, yyyy hh:mm tt")</span>
                </div>
                <div class="flex items-center justify-between py-2 border-b border-slate-50">
                    <span class="text-on-surface-variant text-sm">Purpose</span>
                    <span class="font-semibold text-on-surface">@Model.Purpose</span>
                </div>
                <div class="flex items-center justify-between py-2 border-b border-slate-50">
                    <span class="text-on-surface-variant text-sm">Status</span>
                    <span class="px-3 py-1 rounded-full text-xs font-semibold
                        @(Model.Status=="Scheduled"?"bg-sky-100 text-sky-700":Model.Status=="Completed"?"bg-green-100 text-green-700":"bg-red-100 text-red-700")">
                        @Model.Status
                    </span>
                </div>
                <div class="flex items-center justify-between py-2">
                    <span class="text-on-surface-variant text-sm">Notes</span>
                    <span class="text-on-surface text-sm">@(Model.Notes ?? "—")</span>
                </div>
            </div>
        </div>

        <!-- Patient & Dentist -->
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <h3 class="font-h3 text-h3 text-on-surface mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">people</span> People
            </h3>
            <div class="space-y-3">
                <div class="flex items-center justify-between py-2 border-b border-slate-50">
                    <span class="text-on-surface-variant text-sm">Patient</span>
                    <span class="font-semibold text-on-surface">@Model.Patient?.FullName</span>
                </div>
                <div class="flex items-center justify-between py-2 border-b border-slate-50">
                    <span class="text-on-surface-variant text-sm">Dentist</span>
                    <span class="font-semibold text-on-surface">Dr. @Model.Dentist?.FullName</span>
                </div>
                <div class="flex items-center justify-between py-2">
                    <span class="text-on-surface-variant text-sm">Specialization</span>
                    <span class="text-on-surface text-sm">@Model.Dentist?.Specialization</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Billing if exists -->
    @if (Model.Billing != null)
    {
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 mb-6">
            <h3 class="font-h3 text-h3 text-on-surface mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">payments</span> Billing
            </h3>
            <div class="flex items-center justify-between">
                <div class="space-y-2">
                    <p class="text-sm"><span class="text-on-surface-variant">Total:</span> <strong>₱@Model.Billing.TotalAmount.ToString("N2")</strong></p>
                    <p class="text-sm"><span class="text-on-surface-variant">Paid:</span> <strong class="text-green-600">₱@Model.Billing.AmountPaid.ToString("N2")</strong></p>
                    <span class="px-3 py-1 rounded-full text-xs font-semibold
                        @(Model.Billing.PaymentStatus=="Paid"?"bg-green-100 text-green-700":Model.Billing.PaymentStatus=="Partial"?"bg-yellow-100 text-yellow-700":"bg-red-100 text-red-700")">
                        @Model.Billing.PaymentStatus
                    </span>
                </div>
                <a asp-controller="Billing" asp-action="Details" asp-route-id="@Model.Billing.BillId"
                   class="border border-primary text-primary px-5 py-2 rounded-full font-button hover:bg-primary hover:text-on-primary transition-all">
                    View Bill
                </a>
            </div>
        </div>
    }

    <!-- Actions -->
    <div class="flex flex-wrap gap-3">
        @if (Model.Status == "Scheduled")
        {
            @if (User.IsInRole("Admin") || User.IsInRole("Dentist"))
            {
                <form method="post" asp-action="Complete" asp-route-id="@Model.AppointmentId"
                      onsubmit="return confirm('Mark as completed?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="bg-green-600 text-white px-6 py-3 rounded-full font-button hover:bg-green-700 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">check_circle</span> Mark Completed
                    </button>
                </form>
            }
            <form method="post" asp-action="Cancel" asp-route-id="@Model.AppointmentId"
                  onsubmit="return confirm('Cancel this appointment?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="border border-error text-error px-6 py-3 rounded-full font-button hover:bg-error hover:text-on-error transition-all">
                    Cancel Appointment
                </button>
            </form>
        }
        @if (Model.Status == "Completed" && User.IsInRole("Admin") && Model.Billing == null)
        {
            <a asp-controller="Billing" asp-action="Generate" asp-route-appointmentId="@Model.AppointmentId"
               class="bg-secondary text-on-secondary px-6 py-3 rounded-full font-button hover:opacity-90 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">receipt_long</span> Generate Bill
            </a>
        }
    </div>
</div>
