@model DentalClinic.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign In"; Layout = "_Layout";
}

<div
    class="min-h-[calc(100vh-80px-160px)] flex items-center justify-center py-xl px-md bg-surface relative overflow-hidden">
    <!-- BG blobs -->
    <div class="absolute top-[-10%] left-[-5%] w-96 h-96 bg-primary-fixed/20 rounded-full blur-3xl pointer-events-none">
    </div>
    <div
        class="absolute bottom-[-10%] right-[-5%] w-80 h-80 bg-secondary-container/20 rounded-full blur-3xl pointer-events-none">
    </div>

    <!-- Login Card -->
    <div
        class="relative z-10 w-full max-w-md bg-white p-10 rounded-xl shadow-[0px_4px_20px_rgba(0,0,0,0.05)] border border-slate-100">
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-fixed rounded-full mb-4">
                <span class="material-symbols-outlined text-primary text-3xl">lock_open</span>
            </div>
            <h1 class="font-h2 text-h2 text-on-surface mb-2">Welcome Back</h1>
            <p class="font-body-md text-body-md text-on-surface-variant">Please sign in to manage your appointments.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div
                class="mb-6 flex items-start gap-3 bg-error-container text-on-error-container px-4 py-3 rounded-lg border border-red-200">
                <span class="material-symbols-outlined text-error text-[20px] mt-0.5">error</span>
                <div asp-validation-summary="All" class="text-sm"></div>
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="space-y-6">
                <!-- Username -->
                <div>
                    <label class="block font-label-sm text-label-sm text-on-surface-variant mb-2">Username</label>
                    <div class="relative">
                        <span
                        class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline text-[20px]">person</span>
                        <input asp-for="Username"
                               class="w-full pl-11 pr-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all font-body-md text-on-surface placeholder:text-outline/50"
                               placeholder="Enter username" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Username" class="text-error text-xs mt-1 block"></span>
                </div>
                <!-- Password -->
                <div>
                    <div class="flex justify-between mb-2">
                        <label class="font-label-sm text-label-sm text-on-surface-variant">Password</label>
                    </div>
                    <div class="relative">
                        <span
                        class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline text-[20px]">key</span>
                        <input asp-for="Password" id="pw"
                               class="w-full pl-11 pr-12 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all font-body-md text-on-surface placeholder:text-outline/50"
                               placeholder="••••••••" autocomplete="current-password" />
                        <button type="button" onclick="togglePw()"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-outline hover:text-on-surface transition-colors">
                            <span id="pw-icon" class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-error text-xs mt-1 block"></span>
                </div>
                <!-- Submit -->
                <button type="submit"
                        class="w-full bg-primary text-on-primary font-button text-button py-4 rounded-full shadow-md hover:shadow-lg hover:bg-primary-container active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                    Sign In
                    <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                </button>
            </div>
        </form>

        <div class="mt-8 pt-8 border-t border-slate-100 text-center">
            <p class="font-body-md text-body-md text-on-surface-variant">
                Don't have an account?
                <a asp-controller="Account" asp-action="Register"
                   class="text-primary font-semibold hover:underline decoration-2 underline-offset-4 ml-1">Sign up</a>
            </p>
            <p class="text-xs text-on-surface-variant mt-3 bg-surface-container-low rounded-lg px-4 py-2">
                
            </p>
        </div>
    </div>

    <!-- Decorative side card -->
    <div
        class="hidden lg:block absolute right-[8%] top-[20%] rotate-3 w-60 h-72 bg-white/40 backdrop-blur-xl rounded-2xl border border-white/20 shadow-2xl p-6 overflow-hidden pointer-events-none">
        <div
            class="w-full h-36 bg-gradient-to-br from-primary-fixed to-secondary-container rounded-xl mb-4 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary text-5xl fill-icon">health_and_safety</span>
        </div>
        <div class="space-y-2">
            <div class="h-3 w-3/4 bg-primary/20 rounded"></div>
            <div class="h-3 w-1/2 bg-primary/10 rounded"></div>
            <div class="mt-4 flex gap-2">
                <div class="w-8 h-8 rounded-full bg-tertiary-fixed"></div>
                <div class="w-8 h-8 rounded-full bg-secondary-container"></div>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePw() {
        const pw = document.getElementById('pw');
        const icon = document.getElementById('pw-icon');
        if (pw.type === 'password') { pw.type = 'text'; icon.textContent = 'visibility_off'; }
        else { pw.type = 'password'; icon.textContent = 'visibility'; }
    }
</script>
