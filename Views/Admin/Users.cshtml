@model List<DentalClinic.Models.User>
@{ ViewData["Title"] = "User Management"; }

<div class="max-w-7xl mx-auto px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="font-h2 text-h2 text-on-surface">User Management</h1>
            <p class="text-on-surface-variant text-sm mt-1">Manage system accounts and access</p>
        </div>
        <a asp-action="AddDentist" class="bg-primary text-on-primary font-button py-3 px-6 rounded-full hover:bg-primary-container hover:shadow-lg transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-[20px]">person_add</span> Add Dentist
        </a>
    </div>
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-surface-container-low border-b border-slate-100">
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Username</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Email</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Role</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Status</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Created</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr class="border-b border-slate-50 hover:bg-surface-container-low transition-colors">
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-primary-fixed flex items-center justify-center text-primary font-bold text-xs">
                                        @u.Username[0].ToString().ToUpper()
                                    </div>
                                    <span class="font-medium text-on-surface">@u.Username</span>
                                </div>
                            </td>
                            <td class="py-4 px-6 text-on-surface-variant">@u.Email</td>
                            <td class="py-4 px-6">
                                <span class="px-3 py-1 rounded-full text-xs font-semibold
                                    @(u.Role=="Admin"?"bg-purple-100 text-purple-700":u.Role=="Dentist"?"bg-sky-100 text-sky-700":"bg-green-100 text-green-700")">
                                    @u.Role
                                </span>
                            </td>
                            <td class="py-4 px-6">
                                <span class="px-3 py-1 rounded-full text-xs font-semibold @(u.IsActive?"bg-green-100 text-green-700":"bg-slate-100 text-slate-500")">
                                    @(u.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="py-4 px-6 text-on-surface-variant">@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="py-4 px-6">
                                @if (u.Username != "admin")
                                {
                                    <form method="post" asp-action="ToggleUser" asp-route-id="@u.UserId"
                                          onsubmit="return confirm('Toggle this user?')" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="text-xs font-semibold @(u.IsActive?"text-error hover:underline":"text-green-600 hover:underline")">
                                            @(u.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
