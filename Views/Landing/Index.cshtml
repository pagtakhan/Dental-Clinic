@{
    ViewData["Title"] = "PureSmile Dental – World-Class Care";
    ViewData["HideFooter"] = true;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>PureSmile Dental – World-Class Care</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&family=DM+Mono&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        :root{
            --navy:#0A2540;--blue:#0077B6;--cyan:#00B4D8;--light-cyan:#90E0EF;
            --gold:#FFB703;--white:#FFFFFF;--off-white:#F0F7FF;--gray:#64748b;
        }
        body{font-family:'DM Sans',sans-serif;background:var(--white);overflow-x:hidden;cursor:none}
        h1,h2,h3,.serif{font-family:'Playfair Display',serif}

        /* Custom cursor */
        .cursor{position:fixed;width:12px;height:12px;background:var(--cyan);border-radius:50%;pointer-events:none;z-index:99999;transform:translate(-50%,-50%);transition:transform 0.1s;mix-blend-mode:difference}
        .cursor-ring{position:fixed;width:40px;height:40px;border:2px solid rgba(0,180,216,0.4);border-radius:50%;pointer-events:none;z-index:99998;transform:translate(-50%,-50%);transition:all 0.15s ease}

        /* Animated gradient background */
        .hero-bg{background:linear-gradient(-45deg,#0A2540,#023E8A,#0077B6,#00B4D8,#023E8A,#0A2540);background-size:400% 400%;animation:gradBG 12s ease infinite}
        @@keyframes gradBG{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}

        /* Floating particles */
        .particle{position:absolute;border-radius:50%;animation:floatUp linear infinite;opacity:0}
        @@keyframes floatUp{0%{transform:translateY(100vh) scale(0);opacity:0}10%{opacity:1}90%{opacity:0.3}100%{transform:translateY(-100px) scale(1);opacity:0}}

        /* Text animations */
        .fade-up{opacity:0;transform:translateY(40px);transition:all 0.8s cubic-bezier(0.16,1,0.3,1)}
        .fade-up.show{opacity:1;transform:translateY(0)}
        .fade-left{opacity:0;transform:translateX(-40px);transition:all 0.8s cubic-bezier(0.16,1,0.3,1)}
        .fade-left.show{opacity:1;transform:translateX(0)}
        .fade-right{opacity:0;transform:translateX(40px);transition:all 0.8s cubic-bezier(0.16,1,0.3,1)}
        .fade-right.show{opacity:1;transform:translateX(0)}

        /* Gradient text */
        .grad-text{background:linear-gradient(135deg,var(--cyan),var(--light-cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        .grad-text-gold{background:linear-gradient(135deg,var(--gold),#FB8500);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

        /* Glass card */
        .glass{background:rgba(255,255,255,0.08);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.15)}
        .glass-white{background:rgba(255,255,255,0.95);backdrop-filter:blur(20px);border:1px solid rgba(0,0,0,0.06)}

        /* Hover card */
        .hover-card{transition:all 0.4s cubic-bezier(0.16,1,0.3,1)}
        .hover-card:hover{transform:translateY(-8px);box-shadow:0 30px 80px rgba(0,119,182,0.15)}

        /* Glow button */
        .btn-primary{background:linear-gradient(135deg,var(--blue),var(--cyan));color:white;padding:16px 36px;border-radius:60px;font-weight:600;font-size:16px;border:none;cursor:pointer;position:relative;overflow:hidden;transition:all 0.3s;display:inline-flex;align-items:center;gap:10px;text-decoration:none}
        .btn-primary::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--cyan),var(--blue));opacity:0;transition:opacity 0.3s}
        .btn-primary:hover::before{opacity:1}
        .btn-primary:hover{transform:scale(1.05);box-shadow:0 20px 50px rgba(0,180,216,0.4)}
        .btn-primary span{position:relative;z-index:1}
        .btn-outline{background:transparent;color:white;padding:15px 35px;border-radius:60px;font-weight:600;font-size:16px;border:2px solid rgba(255,255,255,0.4);cursor:pointer;transition:all 0.3s;display:inline-flex;align-items:center;gap:10px;text-decoration:none;backdrop-filter:blur(10px)}
        .btn-outline:hover{background:rgba(255,255,255,0.15);border-color:white;transform:scale(1.05)}

        /* Navbar */
        nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:20px 48px;display:flex;justify-content:space-between;align-items:center;transition:all 0.4s}
        nav.scrolled{background:rgba(10,37,64,0.95);backdrop-filter:blur(20px);padding:14px 48px;box-shadow:0 4px 30px rgba(0,0,0,0.3)}

        /* Stats counter */
        .counter{font-family:'Playfair Display',serif;font-size:3.5rem;font-weight:700;line-height:1}

        /* Service card icon ring */
        .icon-ring{width:64px;height:64px;border-radius:20px;display:flex;align-items:center;justify-content:center;margin-bottom:24px;position:relative}
        .icon-ring::after{content:'';position:absolute;inset:-4px;border-radius:24px;background:linear-gradient(135deg,var(--blue),var(--cyan));z-index:-1;opacity:0.2;transition:opacity 0.3s}
        .hover-card:hover .icon-ring::after{opacity:0.5}

        /* Noise overlay */
        .noise{position:relative}
        .noise::after{content:'';position:absolute;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");pointer-events:none;z-index:1}

        /* Tooth SVG animation */
        @@keyframes toothPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
        .tooth-anim{animation:toothPulse 3s ease-in-out infinite}

        /* Scroll indicator */
        @@keyframes scrollBounce{0%,100%{transform:translateY(0)}50%{transform:translateY(8px)}}
        .scroll-indicator{animation:scrollBounce 2s ease-in-out infinite}

        /* Section divider */
        .section-line{width:60px;height:4px;border-radius:2px;background:linear-gradient(90deg,var(--blue),var(--cyan));margin-bottom:16px}

        /* Testimonial card */
        .quote-mark{font-family:'Playfair Display',serif;font-size:80px;line-height:0.5;color:var(--cyan);opacity:0.3;margin-bottom:16px}

        /* Timeline dot */
        .timeline-dot{width:16px;height:16px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--cyan));flex-shrink:0;margin-top:4px;box-shadow:0 0 0 4px rgba(0,180,216,0.2)}

        /* Material icons */
        .material-symbols-outlined{font-variation-settings:'FILL' 0,'wght' 400,'GRAD' 0,'opsz' 24}
        .fill-icon{font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24}

        /* Number badge */
        .num-badge{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--cyan));color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex-shrink:0}

        /* Ripple */
        @@keyframes ripple{0%{transform:scale(0.8);opacity:1}100%{transform:scale(2.5);opacity:0}}
        .ripple-ring{position:absolute;inset:0;border-radius:50%;border:2px solid rgba(0,180,216,0.5);animation:ripple 2s ease-out infinite}
        .ripple-ring-2{animation-delay:0.7s}
        .ripple-ring-3{animation-delay:1.4s}
    </style>
</head>
<body>

<!-- Custom Cursor -->
<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- ═══════════════════════════════════════════════ NAVBAR -->
<nav id="navbar">
    <a href="/" style="display:flex;align-items:center;gap:12px;text-decoration:none">
        <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#0077B6,#00B4D8);display:flex;align-items:center;justify-content:center">
            <span class="material-symbols-outlined fill-icon" style="color:white;font-size:22px">health_and_safety</span>
        </div>
        <div style="color:white">
            <span style="font-family:'Playfair Display',serif;font-size:20px;font-weight:700">PureSmile</span>
            <span style="font-size:20px;font-weight:300"> Dental</span>
        </div>
    </a>

    <div style="display:flex;align-items:center;gap:36px">
        <a href="#services" style="color:rgba(255,255,255,0.8);text-decoration:none;font-size:15px;font-weight:500;transition:color 0.2s" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.8)'">Services</a>
        <a href="#team" style="color:rgba(255,255,255,0.8);text-decoration:none;font-size:15px;font-weight:500;transition:color 0.2s" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.8)'">Our Team</a>
        <a href="#how" style="color:rgba(255,255,255,0.8);text-decoration:none;font-size:15px;font-weight:500;transition:color 0.2s" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.8)'">How It Works</a>
        <a href="#contact" style="color:rgba(255,255,255,0.8);text-decoration:none;font-size:15px;font-weight:500;transition:color 0.2s" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.8)'">Contact</a>
    </div>

    <div style="display:flex;align-items:center;gap:12px">
        <a asp-controller="Account" asp-action="Login"
           style="color:rgba(255,255,255,0.85);text-decoration:none;font-weight:600;font-size:15px;padding:10px 22px;border-radius:50px;border:1px solid rgba(255,255,255,0.25);transition:all 0.3s;backdrop-filter:blur(10px)"
           onmouseover="this.style.background='rgba(255,255,255,0.12)'" onmouseout="this.style.background='transparent'">
            Sign In
        </a>
        <a asp-controller="Account" asp-action="Register" class="btn-primary" style="padding:10px 24px;font-size:15px">
            <span>Book Appointment</span>
            <span class="material-symbols-outlined" style="font-size:18px">arrow_forward</span>
        </a>
    </div>
</nav>

<!-- ═══════════════════════════════════════════════ HERO -->
<section class="hero-bg noise" style="min-height:100vh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;padding:120px 48px 80px">

    <!-- Floating particles -->
    <div id="particles" style="position:absolute;inset:0;pointer-events:none;overflow:hidden"></div>

    <!-- Decorative circles -->
    <div style="position:absolute;top:-200px;right:-200px;width:600px;height:600px;border-radius:50%;background:rgba(0,180,216,0.08);pointer-events:none"></div>
    <div style="position:absolute;bottom:-150px;left:-150px;width:400px;height:400px;border-radius:50%;background:rgba(0,119,182,0.1);pointer-events:none"></div>

    <!-- Floating tooth illustration -->
    <div class="tooth-anim" style="position:absolute;right:8%;top:50%;transform:translateY(-50%);opacity:0.06;pointer-events:none">
        <svg width="400" height="400" viewBox="0 0 100 100" fill="white">
            <path d="M50 5 C35 5 20 15 18 30 C16 42 20 55 22 65 C24 75 26 90 30 90 C34 90 36 78 38 70 C40 62 44 58 50 58 C56 58 60 62 62 70 C64 78 66 90 70 90 C74 90 76 75 78 65 C80 55 84 42 82 30 C80 15 65 5 50 5Z"/>
        </svg>
    </div>

    <div style="max-width:1200px;margin:0 auto;width:100%;position:relative;z-index:2">
        <div style="max-width:760px">
            <!-- Badge -->
            <div class="fade-up" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.2);border-radius:50px;padding:8px 20px;margin-bottom:40px">
                <div style="width:8px;height:8px;border-radius:50%;background:#00B4D8;animation:pulse 2s infinite"></div>
                <span style="color:rgba(255,255,255,0.9);font-size:14px;font-weight:500;letter-spacing:0.05em">NOW ACCEPTING NEW PATIENTS</span>
            </div>

            <!-- Headline -->
            <h1 class="fade-up serif" style="font-size:clamp(3rem,7vw,5.5rem);font-weight:800;color:white;line-height:1.05;margin-bottom:28px;transition-delay:0.1s">
                Your Smile.<br/>
                <span class="grad-text">Our Masterpiece.</span>
            </h1>

            <p class="fade-up" style="font-size:1.2rem;color:rgba(255,255,255,0.75);line-height:1.8;max-width:540px;margin-bottom:48px;transition-delay:0.2s">
                Experience dentistry reimagined — where cutting-edge technology meets compassionate care. Every visit designed around your comfort and confidence.
            </p>

            <!-- CTA Buttons -->
            <div class="fade-up" style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:72px;transition-delay:0.3s">
                <a asp-controller="Account" asp-action="Register" class="btn-primary" style="font-size:16px">
                    <span>Book Free Consultation</span>
                    <span class="material-symbols-outlined" style="font-size:20px">calendar_month</span>
                </a>
                <a href="#services" class="btn-outline" style="font-size:16px">
                    <span>Explore Services</span>
                    <span class="material-symbols-outlined" style="font-size:20px">arrow_downward</span>
                </a>
            </div>

            <!-- Stats row -->
            <div class="fade-up" style="display:flex;gap:48px;flex-wrap:wrap;transition-delay:0.4s">
                @foreach (var (num, label) in new[]{("2,500+","Happy Patients"),("15+","Expert Dentists"),("98%","Satisfaction Rate"),("10+","Years of Care")})
                {
                    <div>
                        <div class="counter grad-text">@num</div>
                        <div style="color:rgba(255,255,255,0.6);font-size:13px;margin-top:4px;font-weight:500">@label</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator" style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:rgba(255,255,255,0.5)">
        <span style="font-size:12px;letter-spacing:0.1em;text-transform:uppercase">Scroll</span>
        <span class="material-symbols-outlined" style="font-size:20px">keyboard_arrow_down</span>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ TRUST BAR -->
<section style="background:#0A2540;padding:28px 48px">
    <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap">
        @foreach(var (icon, text) in new[]{
            ("verified","ISO Certified Clinic"),
            ("health_and_safety","Sterilized Equipment"),
            ("timer","Same-Day Appointments"),
            ("payments","Flexible Payment Plans"),
            ("support_agent","24/7 Patient Support")
        })
        {
            <div style="display:flex;align-items:center;gap:10px;color:rgba(255,255,255,0.75)">
                <span class="material-symbols-outlined fill-icon" style="color:#00B4D8;font-size:20px">@icon</span>
                <span style="font-size:14px;font-weight:500">@text</span>
            </div>
        }
    </div>
</section>

<!-- ═══════════════════════════════════════════════ SERVICES -->
<section id="services" style="padding:120px 48px;background:#F8FAFF">
    <div style="max-width:1200px;margin:0 auto">
        <div class="fade-up" style="text-align:center;margin-bottom:72px">
            <div class="section-line" style="margin:0 auto 16px"></div>
            <p style="color:var(--blue);font-weight:600;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:16px">What We Offer</p>
            <h2 class="serif" style="font-size:clamp(2rem,4vw,3rem);font-weight:700;color:#0A2540;margin-bottom:20px">
                Comprehensive Dental Care
            </h2>
            <p style="color:#64748b;font-size:1.1rem;max-width:500px;margin:0 auto;line-height:1.7">
                From routine check-ups to complex restorations — we have every aspect of your oral health covered.
            </p>
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px">
            @foreach(var (icon, title, desc, color) in new[]{
                ("dentistry","General Dentistry","Comprehensive exams, cleaning, fillings, and preventive care to keep your smile healthy year-round.","#0077B6"),
                ("auto_awesome","Teeth Whitening","Professional-grade whitening treatments that brighten your smile by up to 8 shades in a single visit.","#00B4D8"),
                ("straighten","Orthodontics","Modern braces and clear aligner solutions for perfectly aligned teeth at any age.","#0096C7"),
                ("healing","Oral Surgery","Expert extractions, implants, and surgical procedures performed with precision and care.","#023E8A"),
                ("child_care","Pediatric Dental","Gentle, fun-focused dental care designed to make children feel safe and comfortable.","#0077B6"),
                ("emergency","Emergency Care","Immediate pain relief and urgent dental care available when you need it most.","#00B4D8")
            })
            {
                <div class="hover-card glass-white" style="padding:32px;border-radius:24px;cursor:pointer">
                    <div class="icon-ring" style="background:rgba(0,119,182,0.08)">
                        <span class="material-symbols-outlined fill-icon" style="color:@color;font-size:28px">@icon</span>
                    </div>
                    <h3 class="serif" style="font-size:1.3rem;font-weight:700;color:#0A2540;margin-bottom:12px">@title</h3>
                    <p style="color:#64748b;font-size:15px;line-height:1.7">@desc</p>
                    <div style="margin-top:24px;display:flex;align-items:center;gap:6px;color:@color;font-weight:600;font-size:14px">
                        <span>Learn more</span>
                        <span class="material-symbols-outlined" style="font-size:16px">arrow_forward</span>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════ HOW IT WORKS -->
<section id="how" style="padding:120px 48px;background:white">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center">
        <div class="fade-left">
            <div class="section-line"></div>
            <p style="color:var(--blue);font-weight:600;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:16px">Simple Process</p>
            <h2 class="serif" style="font-size:clamp(2rem,3.5vw,2.8rem);font-weight:700;color:#0A2540;margin-bottom:48px;line-height:1.2">
                Book Your Visit<br/>in 3 Easy Steps
            </h2>

            <div style="display:flex;flex-direction:column;gap:36px">
                @foreach(var (num, title, desc) in new[]{
                    ("1","Create Your Account","Register online in under 2 minutes. No paperwork, no waiting rooms."),
                    ("2","Choose Your Dentist","Browse our expert team and select the specialist that fits your needs."),
                    ("3","Confirm & Attend","Pick your preferred time slot and show up. We handle the rest.")
                })
                {
                    <div style="display:flex;gap:20px;align-items:flex-start">
                        <div class="num-badge">@num</div>
                        <div>
                            <h3 style="font-size:1.1rem;font-weight:700;color:#0A2540;margin-bottom:6px">@title</h3>
                            <p style="color:#64748b;font-size:15px;line-height:1.6">@desc</p>
                        </div>
                    </div>
                }
            </div>

            <div style="margin-top:48px">
                <a asp-controller="Account" asp-action="Register" class="btn-primary">
                    <span>Start Now – It's Free</span>
                    <span class="material-symbols-outlined" style="font-size:18px">arrow_forward</span>
                </a>
            </div>
        </div>

        <!-- Visual card -->
        <div class="fade-right" style="position:relative">
            <div style="background:linear-gradient(135deg,#0077B6,#00B4D8);border-radius:32px;padding:48px;position:relative;overflow:hidden;box-shadow:0 40px 80px rgba(0,119,182,0.25)">
                <!-- Glow -->
                <div style="position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,0.1);pointer-events:none"></div>

                <div style="position:relative;z-index:1">
                    <div style="display:flex;align-items:center;gap:12px;margin-bottom:32px">
                        <div style="position:relative">
                            <div style="width:56px;height:56px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center">
                                <span class="material-symbols-outlined fill-icon" style="color:white;font-size:28px">health_and_safety</span>
                            </div>
                            <div class="ripple-ring"></div>
                            <div class="ripple-ring ripple-ring-2"></div>
                        </div>
                        <div style="color:white">
                            <div style="font-weight:700;font-size:1.1rem">Dr. Strange</div>
                            <div style="opacity:0.75;font-size:13px">General Dentist • 12 yrs exp.</div>
                        </div>
                    </div>

                    <div style="background:rgba(255,255,255,0.12);border-radius:16px;padding:20px;margin-bottom:16px">
                        <div style="color:rgba(255,255,255,0.7);font-size:12px;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:8px">Next Available</div>
                        <div style="color:white;font-size:1.2rem;font-weight:700">Tomorrow, 9:00 AM</div>
                        <div style="color:rgba(255,255,255,0.7);font-size:13px;margin-top:4px">Dental Check-up & Cleaning</div>
                    </div>

                    @foreach(var (time, type, avail) in new[]{
                        ("10:30 AM","Consultation","Available"),
                        ("2:00 PM","Whitening","Available"),
                        ("4:30 PM","X-Ray","Booked")
                    })
                    {
                        <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.1);color:white">
                            <span style="font-size:14px;opacity:0.8">@time</span>
                            <span style="font-size:14px;font-weight:500">@type</span>
                            <span style="font-size:12px;padding:4px 10px;border-radius:20px;font-weight:600;background:@(avail=="Available"?"rgba(0,255,150,0.2)":"rgba(255,100,100,0.2)");color:@(avail=="Available"?"#4ade80":"#fca5a5")">@avail</span>
                        </div>
                    }

                    <a asp-controller="Account" asp-action="Register"
                       style="display:block;text-align:center;background:white;color:#0077B6;border-radius:50px;padding:14px;font-weight:700;font-size:15px;margin-top:20px;text-decoration:none;transition:all 0.3s"
                       onmouseover="this.style.background='rgba(255,255,255,0.9)';this.style.transform='scale(1.02)'"
                       onmouseout="this.style.background='white';this.style.transform='scale(1)'">
                        Book This Slot
                    </a>
                </div>
            </div>

