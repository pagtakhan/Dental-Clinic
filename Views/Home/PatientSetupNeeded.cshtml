@{
    ViewData["Title"] = "Setup Needed";
}

<div class="min-h-[60vh] flex items-center justify-center px-8">
    <div class="text-center">
        <div class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6"
             style="background:rgba(0,180,216,0.1)">
            <span class="material-symbols-outlined fill-icon text-4xl" style="color:#0077B6">warning</span>
        </div>
        <h1 class="font-clash text-4xl font-semibold mb-3" style="color:#0A2540">Account Setup Incomplete</h1>
        <p class="text-slate-500 text-lg max-w-md mx-auto mb-8">
            Your patient profile is not fully set up yet. Please contact the clinic administrator to complete your
            registration.
        </p>
        <div class="flex gap-4 justify-center">
            <a asp-controller="Account" asp-action="Logout"
                   class="px-8 py-3 rounded-xl text-white font-semibold shadow-lg hover:scale-105 transition-all"
                   style="background:linear-gradient(135deg,#0077B6,#00B4D8)">
                Back to Login
            </a>
        </div>
    </div>
</div>