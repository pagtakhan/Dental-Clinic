@model List<DentalClinic.Models.Patient>
@{ ViewData["Title"] = "Patient Records"; }

<div class="max-w-7xl mx-auto px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="font-h2 text-h2 text-on-surface">Patient Records</h1>
            <p class="text-on-surface-variant text-sm mt-1">Search and manage patient information</p>
        </div>
    </div>

    <form method="get" class="mb-6 flex gap-3">
        <div class="relative flex-1 max-w-md">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-[20px]">search</span>
            <input name="search" value="@ViewBag.Search" class="w-full pl-12 pr-4 py-3 bg-white border border-outline-variant rounded-full focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none font-body-md" placeholder="Search by name or contact number..."/>
        </div>
        <button type="submit" class="bg-primary text-on-primary px-6 py-3 rounded-full font-button hover:bg-primary-container transition-all">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a asp-action="Index" class="border border-outline-variant text-on-surface px-6 py-3 rounded-full font-button hover:bg-surface-container transition-all">Clear</a>
        }
    </form>

    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-surface-container-low border-b border-slate-100">
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Full Name</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Date of Birth</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Contact</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Allergies</th>
                        <th class="text-left py-4 px-6 font-label-sm text-on-surface-variant">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center py-16 text-on-surface-variant">
                            <span class="material-symbols-outlined text-5xl text-outline mb-3 block">person_search</span>
                            No patients found.
                        </td></tr>
                    }
                    @foreach (var p in Model)
                    {
                        <tr class="border-b border-slate-50 hover:bg-surface-container-low transition-colors">
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-primary-fixed flex items-center justify-center text-primary font-bold text-sm">
                                        @p.FullName[0]
                                    </div>
                                    <span class="font-medium text-on-surface">@p.FullName</span>
                                </div>
                            </td>
                            <td class="py-4 px-6 text-on-surface-variant">@p.DateOfBirth.ToString("MMM dd, yyyy")</td>
                            <td class="py-4 px-6 text-on-surface-variant">@p.ContactNumber</td>
                            <td class="py-4 px-6">
                                @if (string.IsNullOrEmpty(p.Allergies))
                                {
                                    <span class="text-on-surface-variant text-xs">None</span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-error-container text-on-error-container text-xs rounded-full">@p.Allergies</span>
                                }
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-3">
                                    <a asp-action="Details" asp-route-id="@p.PatientId" class="text-primary hover:underline font-label-sm">View</a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@p.PatientId" class="text-secondary hover:underline font-label-sm">Edit</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
