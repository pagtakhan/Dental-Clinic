@model DentalClinic.Models.BillingViewModel
@{
    ViewData["Title"] = "Generate Bill";
    var appt = ViewBag.Appointment as DentalClinic.Models.Appointment;
}
<div class="max-w-2xl mx-auto px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="font-h2 text-h2 text-on-surface">Generate Bill</h1>
            <p class="text-on-surface-variant text-sm mt-1">Create a billing record for this appointment</p>
        </div>
        <a asp-controller="Appointments" asp-action="Index" class="flex items-center gap-2 text-on-surface-variant hover:text-primary font-button transition-colors">
            <span class="material-symbols-outlined">arrow_back</span> Back
        </a>
    </div>

    @if (appt != null)
    {
        <div class="bg-surface-container-low rounded-xl p-4 mb-6 flex items-center gap-3">
            <span class="material-symbols-outlined text-primary fill-icon">calendar_today</span>
            <div class="text-sm">
                <span class="font-semibold text-on-surface">@appt.Patient?.FullName</span>
                <span class="text-on-surface-variant mx-2">•</span>
                <span class="text-on-surface-variant">@appt.AppointmentDate.ToString("MMMM dd, yyyy hh:mm tt")</span>
                <span class="text-on-surface-variant mx-2">•</span>
                <span class="text-on-surface-variant">@appt.Purpose</span>
            </div>
        </div>
    }

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AppointmentId"/>
            <div class="space-y-6">
                <div>
                    <label class="block font-label-sm text-label-sm text-on-surface-variant mb-2">Services Rendered *</label>
                    <textarea asp-for="Services" rows="3"
                              class="w-full px-4 py-3 bg-white border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none font-body-md"
                              placeholder="e.g., Tooth Extraction – ₱800, Oral Prophylaxis – ₱600"></textarea>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block font-label-sm text-label-sm text-on-surface-variant mb-2">Total Amount (₱) *</label>
                        <input asp-for="TotalAmount" type="number" step="0.01" min="0" id="totalAmt"
                               class="w-full px-4 py-3 bg-white border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none font-body-md"
                               placeholder="0.00" oninput="updateBal()"/>
                    </div>
                    <div>
                        <label class="block font-label-sm text-label-sm text-on-surface-variant mb-2">Amount Paid (₱)</label>
                        <input asp-for="AmountPaid" type="number" step="0.01" min="0" id="amtPaid"
                               class="w-full px-4 py-3 bg-white border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none font-body-md"
                               placeholder="0.00" oninput="updateBal()"/>
                    </div>
                </div>
                <div class="flex items-center justify-between bg-surface-container-low rounded-xl p-4">
                    <div>
                        <p class="text-sm text-on-surface-variant">Balance Due</p>
                        <p id="balDisplay" class="text-2xl font-bold text-error">₱0.00</p>
                    </div>
                    <span id="statusDisplay" class="px-4 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-700">Unpaid</span>
                </div>
                <div class="flex gap-4 pt-2">
                    <button type="submit" class="flex-1 bg-primary text-on-primary py-4 rounded-full font-button hover:bg-primary-container hover:shadow-lg transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-[20px]">receipt_long</span> Generate Bill
                    </button>
                    <a asp-controller="Appointments" asp-action="Index" class="px-6 py-4 border border-outline-variant text-on-surface rounded-full font-button hover:bg-surface-container transition-all text-center">
                        Cancel
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>
<script>
function updateBal(){
    const t=parseFloat(document.getElementById('totalAmt').value)||0;
    const p=parseFloat(document.getElementById('amtPaid').value)||0;
    const b=t-p;
    document.getElementById('balDisplay').textContent='₱'+b.toFixed(2);
    const s=document.getElementById('statusDisplay');
    if(p>=t&&t>0){s.textContent='Paid';s.className='px-4 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700';}
    else if(p>0){s.textContent='Partial';s.className='px-4 py-1 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-700';}
    else{s.textContent='Unpaid';s.className='px-4 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-700';}
}
</script>
